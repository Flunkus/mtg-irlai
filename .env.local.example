# MTG Trainer environment variables.
# Copy this file to .env.local (which is gitignored) and fill in.
#
# After editing .env.local you must RESTART the dev server (`npm run dev`).
# Vite only reads env vars on boot, not on hot reload.

# ── Anthropic API key (optional) ──────────────────────────────────────────
# Get one at https://console.anthropic.com → API keys → Create Key.
# Without a key the app still runs; the AI brain falls back to a local mock
# proposal and the voice parser shows an inline "key missing" message.
#
# SECURITY: this key is bundled into the browser at build time. Acceptable
# for local single-user use; do NOT deploy this app publicly with a real key.
VITE_ANTHROPIC_API_KEY=
